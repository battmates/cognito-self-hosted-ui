APP_NAME="RSL Group Auth"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=480
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-2
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

COGNITO_REGION=eu-west-2
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=
COGNITO_AUTH_FLOW=USER_PASSWORD_AUTH
COGNITO_DOMAIN=
COGNITO_REDIRECT_URI="${APP_URL}/callback"
COGNITO_LOGOUT_URI="${APP_URL}/logout"
COGNITO_SCOPES="email phone openid"

SSO_STATE_TTL_SECONDS=300
SSO_CLAIM_SUBJECT=sub
SSO_CLAIM_EMAIL=email
SSO_CLAIM_FIRST_NAME=given_name
SSO_CLAIM_LAST_NAME=family_name
SSO_CLAIM_ROLES="custom:user_type,cognito:groups"

SSO_SITE_WORDPRESS_LABEL="Rockschool Backstage"
SSO_SITE_WORDPRESS_DRIVER=wordpress
SSO_SITE_WORDPRESS_BASE_URL=
SSO_SITE_WORDPRESS_LOGIN_PATH=/wp-login.php
SSO_SITE_WORDPRESS_CALLBACK_PATH=/cognito-login
SSO_SITE_WORDPRESS_LOGOUT_PATH=/logout
SSO_SITE_WORDPRESS_ALLOWED_RETURN_HOSTS=
